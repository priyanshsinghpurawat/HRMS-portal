PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
BASE_URL=http://localhost:3000

# Database
MONGODB_URI=mongodb://localhost:27017/jobdekho

# Authentication
JWT_SECRET_KEY=your_jwt_access_token_secret_key
ACCESS_TOKEN_EXPIRY=1d
REFRESH_TOKEN_SECRET=your_jwt_refresh_token_secret_key
REFRESH_TOKEN_EXPIRY=7d

# Cloud Storage (Cloudinary)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Payments (Razorpay)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Email Service (Nodemailer SMTP)
EMAIL_USER=your_smtp_email_user@gmail.com
EMAIL_PASS=your_smtp_app_password
EMAIL_FROM=your_smtp_email_user@gmail.com

# AI Services
GEMINI_API_KEY=your_gemini_api_key
